#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$root"

usage() {
  cat <<'USAGE'
Usage:
  ./beater-cli format [--check]
  ./beater-cli dev [docker compose args...]
  ./beater-cli down [docker compose args...]
  ./beater-cli update-schema [--check]
  ./beater-cli test [backend|frontend|agents|algorithms|all]

Commands:
  format         Run cargo fmt for the workspace.
  dev            Start the local beaterd + dashboard compose stack.
  down           Stop the local compose stack.
  update-schema  Regenerate OpenAPI, SDK, dashboard, and semconv artifacts.
  test           Run the local verification lanes. Defaults to all.
USAGE
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: missing required command: $1" >&2
    exit 127
  fi
}

format_workspace() {
  if [[ "${1:-}" == "--check" ]]; then
    cargo fmt --all -- --check
  else
    cargo fmt --all
  fi
}

dev_stack() {
  need docker
  docker compose up --build beaterd dashboard "$@"
}

down_stack() {
  need docker
  docker compose down "$@"
}

update_schema() {
  if [[ "${1:-}" == "--check" ]]; then
    cargo xtask check-drift
    cargo xtask regen-semconv
    git diff --exit-code -- sdks/semconv/conventions.json
    scripts/check-contract-sync.sh
  else
    cargo xtask regen-spec
    scripts/regen-sdks.sh
    cargo xtask regen-semconv
    scripts/check-contract-sync.sh
  fi
}

test_backend() {
  cargo test --workspace \
    --exclude beaterd \
    --exclude beater-browser \
    --exclude beater-browser-capture \
    --exclude beater-browser-cdp \
    --exclude beater-browser-harness \
    --exclude beater-browser-playwright \
    --exclude beater-browser-webdriver
  cargo test -p beaterd --test sqlite_migrations
  (
    cd sdks/rust
    cargo build --examples
  )
  if [[ "${BEATER_DOCKER_BACKENDS:-0}" == "1" ]]; then
    need docker
    docker info >/dev/null
    docker pull postgres:16-alpine
    docker pull clickhouse/clickhouse-server:24-alpine
    cargo test -p beater-store-sql -- --ignored
  fi
}

test_frontend() {
  need npm
  (
    cd web/dashboard
    npm ci
    npm test
    npm run build
    npx tsc --noEmit -p tsconfig.json
  )
  scripts/check-openapi-drift.sh
}

test_agents() {
  cargo test \
    -p beater-browser \
    -p beater-browser-capture \
    -p beater-browser-cdp \
    -p beater-browser-harness \
    -p beater-browser-playwright \
    -p beater-browser-webdriver
  cargo test -p beaterd --test live_smoke -- --test-threads=1
  bash scripts/browser-e2e.sh
  if [[ "${BEATER_GATE2_BROWSER_PROOF:-0}" == "1" ]]; then
    scripts/gate2-proof.sh
  else
    echo "Skipping Gate 2 live browser proof; set BEATER_GATE2_BROWSER_PROOF=1 to run it."
  fi
}

test_algorithms() {
  cargo test -p beater-api --test openapi_coverage
  update_schema --check
  scripts/check-gate0-foundations.py
  scripts/validate-gate2-outside-proof.sh --allow-pending
  cargo test -p beaterd --test self_host_contract
  cargo test -p beaterd --test gate2_outside_validator
}

test_all() {
  test_backend
  test_frontend
  test_agents
  test_algorithms
}

cmd="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$cmd" in
  format)
    format_workspace "$@"
    ;;
  dev)
    dev_stack "$@"
    ;;
  down)
    down_stack "$@"
    ;;
  update-schema)
    update_schema "$@"
    ;;
  test)
    target="${1:-all}"
    case "$target" in
      backend) test_backend ;;
      frontend) test_frontend ;;
      agents) test_agents ;;
      algorithms) test_algorithms ;;
      all) test_all ;;
      *)
        echo "error: unknown test target: $target" >&2
        usage >&2
        exit 2
        ;;
    esac
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "error: unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
