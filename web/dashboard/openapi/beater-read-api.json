  "paths": {
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "operationId": "openapi_health",
        "responses": {
          "200": {
            "description": "Runtime is accepting requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDoc"
                }
              }
            }
          }
        }
      }
    },
    "/v1/spans/{tenant_id}/{trace_id}/{span_id}": {
      "get": {
        "tags": [
          "traces"
        ],
        "operationId": "openapi_get_span",
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "description": "Tenant id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trace_id",
            "in": "path",
            "description": "Trace id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "span_id",
            "in": "path",
            "description": "Span id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "unmask",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "reason",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "description": "Bearer API token for strict auth",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "x-beater-api-key",
            "in": "header",
            "description": "API key alternative for strict auth",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "x-beater-project-id",
            "in": "header",
            "description": "Strict-auth project scope",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "x-beater-environment-id",
            "in": "header",
            "description": "Strict-auth environment scope",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Canonical span with redaction applied unless unmasked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CanonicalSpanDoc"
                }
              }
            }
          },
          "400": {
            "description": "Invalid scope or query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDoc"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDoc"
                }
              }
            }
          },
          "403": {
            "description": "API key lacks trace read or unmask scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDoc"
                }
              }
            }
          },
          "404": {
            "description": "Span or trace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDoc"
                }
              }
            }
          }
        }
      }
    },
