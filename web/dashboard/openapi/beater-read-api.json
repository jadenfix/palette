  },
  "components": {
    "schemas": {
      "ArtifactRefDoc": {
        "type": "object",
        "required": [
          "artifact_id",
          "uri",
          "sha256",
          "size_bytes",
          "mime_type",
          "redaction_class"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "mime_type": {
            "type": "string"
          },
          "redaction_class": {
            "type": "string",
            "example": "internal"
          },
          "sha256": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "uri": {
            "type": "string"
          }
        }
      },
      "CanonicalSpanDoc": {
        "type": "object",
        "required": [
          "schema_version",
          "normalizer_version",
          "tenant_id",
          "project_id",
          "environment_id",
          "trace_id",
          "span_id",
          "seq",
          "kind",
          "name",
          "status",
          "start_time",
          "attributes",
          "unmapped_attrs",
          "raw_ref"
        ],
        "properties": {
          "attributes": {},
          "cost": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/MoneyDoc"
              }
            ]
          },
          "end_time": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "environment_id": {
            "type": "string"
          },
          "input_ref": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ArtifactRefDoc"
              }
            ]
          },
          "kind": {
            "type": "string",
            "example": "llm.call"
          },
          "model": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ModelRefDoc"
              }
            ]
          },
          "name": {
            "type": "string"
          },
          "normalizer_version": {
            "type": "string"
          },
          "output_ref": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ArtifactRefDoc"
              }
            ]
          },
          "parent_span_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "project_id": {
            "type": "string"
          },
          "raw_ref": {
            "$ref": "#/components/schemas/ArtifactRefDoc"
          },
          "schema_version": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "seq": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "span_id": {
            "type": "string"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "example": "ok"
          },
          "tenant_id": {
            "type": "string"
          },
          "tokens": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/TokenCountsDoc"
              }
            ]
          },
          "trace_id": {
            "type": "string"
          },
          "unmapped_attrs": {}
        }
      },
      "ErrorResponseDoc": {
        "type": "object",
        "required": [
          "error",
          "status"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "HealthResponseDoc": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "ModelRefDoc": {
        "type": "object",
        "required": [
          "provider",
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          }
        }
      },
      "MoneyDoc": {
        "type": "object",
        "required": [
          "amount_micros",
          "currency"
        ],
        "properties": {
          "amount_micros": {
            "type": "integer",
            "format": "int64"
          },
          "currency": {
            "type": "string",
            "example": "USD"
          }
        }
      },
      "PageRunSummaryDoc": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RunSummaryDoc"
            }
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "RunSummaryDoc": {
        "type": "object",
        "required": [
          "tenant_id",
          "trace_id",
          "first_span_name",
          "span_count",
          "status",
          "started_at",
          "models",
          "release_ids"
        ],
        "properties": {
          "duration_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "ended_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "first_span_name": {
            "type": "string"
          },
          "models": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelRefDoc"
            }
          },
          "release_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "span_count": {
            "type": "integer",
            "minimum": 0
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "example": "ok"
          },
          "tenant_id": {
            "type": "string"
          },
          "total_cost": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/MoneyDoc"
              }
            ]
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "SpanIoResponseDoc": {
        "type": "object",
        "required": [
          "tenant_id",
          "trace_id",
          "span_id",
          "input",
          "output"
        ],
        "properties": {
          "input": {
            "$ref": "#/components/schemas/SpanIoValueDoc"
          },
          "output": {
            "$ref": "#/components/schemas/SpanIoValueDoc"
          },
          "span_id": {
            "type": "string"
          },
          "tenant_id": {
            "type": "string"
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "SpanIoValueDoc": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "value",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "inline"
                ]
              },
              "value": {}
            }
          },
          {
            "type": "object",
            "required": [
              "artifact_ref",
              "kind"
            ],
            "properties": {
              "artifact_ref": {
                "$ref": "#/components/schemas/ArtifactRefDoc"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "artifact"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "reason",
              "kind"
            ],
