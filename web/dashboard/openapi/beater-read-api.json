    "/v1/traces/{tenant_id}": {
      "get": {
        "tags": [
          "traces"
        ],
        "operationId": "openapi_list_traces",
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "description": "Tenant id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "project_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trace_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "kind",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "llm.call"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "ok"
          },
          {
            "name": "started_after",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "2026-01-01T00:00:00Z"
          },
          {
            "name": "started_before",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "2026-01-01T01:00:00Z"
          },
          {
            "name": "model",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "gpt-4.1"
          },
          {
            "name": "release",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "release-a"
          },
          {
            "name": "min_cost_micros",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "max_cost_micros",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "min_latency_ms",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "max_latency_ms",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "description": "Bearer API token for strict auth",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "x-beater-api-key",
            "in": "header",
            "description": "API key alternative for strict auth",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "x-beater-project-id",
            "in": "header",
            "description": "Strict-auth project scope",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "x-beater-environment-id",
            "in": "header",
            "description": "Strict-auth environment scope",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trace run summaries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageRunSummaryDoc"
                }
              }
            }
          },
          "400": {
            "description": "Invalid scope or filter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDoc"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDoc"
                }
              }
            }
          },
          "403": {
            "description": "API key lacks trace read scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDoc"
                }
              }
            }
          }
        }
      }
    },
